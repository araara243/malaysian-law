# OpenRouter API Key (Recommended - Free models available)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini API Key (Optional alternative)
GOOGLE_API_KEY=your_google_api_key_here

# Optional: LangSmith/LangChain Tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langchain_api_key_here

# PostgreSQL Configuration (for PostgreSQL + pgvector backend)
PGHOST=localhost
PGPORT=5432
PGDATABASE=mylaw_rag
PGUSER=postgres
PGPASSWORD=your_password_here
